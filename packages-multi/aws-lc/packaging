set -euxo pipefail

source haproxy-versions.sh

export PATH=/var/vcap/packages/cmake/bin:$PATH

tar xzf haproxy/aws-lc-v${AWS_LC_VERSION}.tar.gz
pushd aws-lc-${AWS_LC_VERSION}
  mkdir -p build && cd build
  cmake -DCMAKE_BUILD_TYPE=RelWithDebInfo \
        -DBUILD_SHARED_LIBS=0 \
        -DDISABLE_GO=1 \
        -DDISABLE_PERL=1 \
        -DBUILD_TESTING=0 \
        -DCMAKE_INSTALL_PREFIX=${BOSH_INSTALL_TARGET} \
        ..
  make -j$(nproc)
  make install
popd
